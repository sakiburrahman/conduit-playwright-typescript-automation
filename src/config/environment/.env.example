# Base URLs only — required for every run.
# DYNAMIC_USER=true (default in package.json / all-test-run.sh): each run registers a new user.
# No EMAIL / USERNAME / PASSWORD needed unless DYNAMIC_USER=false.

# Dev environment
DEV_BASEURL=https://conduit.bondaracademy.com
DEV_API_BASE_URL=https://conduit-api.bondaracademy.com

# QA environment
QA_BASEURL=https://conduit.bondaracademy.com
QA_API_BASE_URL=https://conduit-api.bondaracademy.com

# UAT environment
UAT_BASEURL=https://conduit.bondaracademy.com
UAT_API_BASE_URL=https://conduit-api.bondaracademy.com

# Optional — only when DYNAMIC_USER=false:
# DEV_EMAIL=your-dev-email@example.com
# DEV_USERNAME=Your Dev Username
# DEV_PASSWORD=YourDevPassword
# QA_EMAIL=your-qa-email@example.com
# QA_USERNAME=Your QA Username
# QA_PASSWORD=YourQaPassword
# UAT_EMAIL=your-uat-email@example.com
# UAT_USERNAME=Your UAT Username
# UAT_PASSWORD=YourUatPassword
